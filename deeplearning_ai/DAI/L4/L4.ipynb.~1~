    "# --- 0) OCR tool (assumes you already defined paddle_ocr_read_document) ---\n",
    "# It should return something like:\n",
    "# {\n",
    "#   \"texts\": [...],\n",
    "#   \"scores\": [...],\n",
    "#   \"boxes\":  [...],   # list of 4-point polygons\n",
    "#   \"full_text\": \"...\"\n",
    "# }\n",
    "# tools = [paddle_ocr_read_document]  # keep as reference, but we won't use LC agents\n",
    "\n",
    "# --- 1) Set up the OpenAI GPT model (LangChain OpenAI wrapper) ---\n",
    "from langchain_openai import ChatOpenAI\n",
    "\n",
    "llm = ChatOpenAI(\n",
    "    model=\"gpt-5-mini\",\n",
    "    temperature=1,\n",
    ")\n",
    "\n",
    "# --- 2) Define a prompt (no MessagesPlaceholder / agent_scratchpad needed) ---\n",
    "from langchain_core.prompts import ChatPromptTemplate\n",
    "\n",
    "prompt = ChatPromptTemplate.from_messages([\n",
    "    (\"system\",\n",
    "     \"You are a helpful assistant designed to extract information from documents.\\n\"\n",
    "     \"You will be given OCR output (raw text plus optional boxes/scores).\\n\"\n",
    "     \"Return a clean JSON object with the fields you can confidently extract.\\n\"\n",
    "     \"If a field is missing/uncertain, set it to null and explain briefly in notes.\"),\n",
    "    (\"user\",\n",
    "     \"User request:\\n{user_request}\\n\\n\"\n",
    "     \"OCR full text:\\n{ocr_text}\\n\\n\"\n",
    "     \"OCR lines (text | score | box):\\n{ocr_lines}\\n\")\n",
    "])\n",
    "\n",
    "# --- 3) A helper function to run OCR + LLM together ---\n",
    "import json\n",
    "\n",
    "def extract_from_document(image_path: str, user_request: str) -> dict:\n",
    "    # Call your OCR tool directly (MOST RELIABLE in your env)\n",
    "    #ocr_out = paddle_ocr_read_document(image_path)\n",
    "    ocr_out = paddle_ocr_read_document.invoke({\"image_path\": image_path})\n",
    "\n",
    "    ocr_text = ocr_out.get(\"full_text\") or \"\\n\".join(ocr_out.get(\"texts\", []))\n",
    "\n",
    "    # Build a compact “lines” view (truncate if huge)\n",
    "    texts  = ocr_out.get(\"texts\", [])\n",
    "    scores = ocr_out.get(\"scores\", [])\n",
    "    boxes  = ocr_out.get(\"boxes\", [])\n",
    "\n",
    "    lines = []\n",
    "    for t, s, b in zip(texts, scores, boxes):\n",
    "        # b is typically list of points: [[x,y],...]\n",
    "        coords = [[int(x), int(y)] for x, y in b] if isinstance(b, list) else b\n",
    "        lines.append(f\"{t} | {float(s):.3f} | {coords}\")\n",
    "    ocr_lines = \"\\n\".join(lines[:200])  # cap to avoid huge prompts\n",
    "\n",
    "    # Send to LLM\n",
    "    msg = prompt.format_messages(\n",
    "        user_request=user_request,\n",
    "        ocr_text=ocr_text,\n",
    "        ocr_lines=ocr_lines\n",
    "    )\n",
    "    resp = llm.invoke(msg)\n",
    "\n",
    "    # Try to parse JSON; if model returns non-JSON, wrap it\n",
    "    content = resp.content.strip()\n",
    "    try:\n",
    "        return json.loads(content)\n",
    "    except Exception:\n",
    "        return {\"raw_response\": content, \"notes\": \"Model did not return valid JSON.\"}\n",
    "\n",
    "# --- 4) Example usage ---\n",
    "# result = extract_from_document(\"sample.png\", \"Extract invoice number, date, vendor, total amount.\")\n",
    "# print(result)\n"
